{
  "name": "deal-tracker",
  "productName": "Dealia",
  "version": "1.0.6",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently --kill-others \"npm run vite:dev\" \"npm run electron:dev\"",
    "vite:dev": "vite --config vite.renderer.config.mts --port 5173",
    "electron:dev": "wait-on http://localhost:5173 && electron-forge start",
    "start:forge": "electron-forge start",
    "build:icons": "node scripts/build-icons.js",
    "package": "npm run build:icons && electron-forge package",
    "make": "npm run build:icons && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
  "author": "matt.marontate",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "40.6.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "better-sqlite3": "^12.6.2",
    "electron-squirrel-startup": "^1.0.1",
    "node-cron": "^4.2.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  }
}
